# ── Required ──────────────────────────────────────────────────────────────────

# Google Gemini API key — used to natively ingest a YouTube URL (video + audio)
# and generate structured chapter files with Gemini's video understanding.
# Optional — if not set, yt-dlp extracts captions/metadata and the pi agent
# generates chapters from that transcript instead. Poiesis works without this
# key as long as the video has captions or a description.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Promptfoo eval (CI only) ───────────────────────────────────────────────────
# Locally, promptfoo reads ~/.pi/agent/settings.json + models.json automatically.
# These are only needed in CI (GitHub Actions) where ~/.pi doesn't exist.
# Add them as GitHub repo secrets: Settings → Secrets → Actions.

# Any Anthropic API key (or your proxy key if PI_BASE_URL is set)
PI_API_KEY=

# Optional — defaults to https://api.anthropic.com
# Set to your proxy base URL if you want CI to hit the same endpoint as local dev
# PI_BASE_URL=http://your-proxy:8787

# Optional — defaults to claude-haiku-4-5-20251001
# PI_MODEL=claude-sonnet-4-6

# Optional — defaults to anthropic-messages
# Set to openai-completions if using an OpenAI-compatible provider (e.g. opencode)
# PI_API=openai-completions
